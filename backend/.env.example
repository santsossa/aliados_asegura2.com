# ─── Admin inicial (solo para seed) ─────────────────────────
ADMIN_EMAIL=tu_correo@dominio.com
ADMIN_PASSWORD=contrasena_segura_aqui
ADMIN_NOMBRE=Administrador

# ─── Servidor ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development          # development | production

# ─── Base de datos (MySQL) ───────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=aliados_db
DB_USER=root
DB_PASSWORD=tu_password_aqui

# ─── JWT ─────────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_seguro_de_64_bytes
JWT_REFRESH_SECRET=cambia_esto_por_otro_secreto_seguro_diferente
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── OTP ─────────────────────────────────────────────────────
OTP_EXPIRES_MINUTES=10

# ─── Email (Resend) ──────────────────────────────────────────
# Obtén tu API key en https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@asegura2.com.co
EMAIL_FROM_NAME=Asegura2.com - Portal de Aliados

# ─── Frontend ────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5176

# ─── Rate limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 minutos
RATE_LIMIT_MAX=100            # máx requests por ventana
