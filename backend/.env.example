# ─────────────────────────────────────────────────────────────────────────────
# BACKEND — Variables de entorno para producción en Railway
# Copia este archivo, rellena los valores y pégalos en Railway → Variables
# ─────────────────────────────────────────────────────────────────────────────

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── Base de datos MySQL (Railway te los da al crear el servicio MySQL) ────────
# En Railway: New Service → Database → MySQL
# Copia los valores desde la pestaña "Connect" del servicio MySQL
DB_HOST=           # ← MYSQLHOST de Railway
DB_PORT=3306       # ← MYSQLPORT de Railway (normalmente 3306)
DB_NAME=           # ← MYSQLDATABASE de Railway
DB_USER=           # ← MYSQLUSER de Railway
DB_PASSWORD=       # ← MYSQLPASSWORD de Railway

# ─── JWT — GENERA NUEVOS SECRETS PARA PRODUCCIÓN ──────────────────────────────
# Ejecuta este comando y copia los resultados:
# node -e "const c=require('crypto');console.log('JWT_SECRET='+c.randomBytes(64).toString('hex'));console.log('JWT_REFRESH_SECRET='+c.randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── OTP ──────────────────────────────────────────────────────────────────────
OTP_EXPIRES_MINUTES=10

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Obtén tu API key en https://resend.com → API Keys
RESEND_API_KEY=
EMAIL_FROM=noreply@asegura2.com.co
EMAIL_FROM_NAME=Asegura2.com - Portal de Aliados

# ─── URLs ─────────────────────────────────────────────────────────────────────
# Pon la URL del servicio frontend de Railway (después de desplegarlo)
FRONTEND_URL=https://tu-frontend.up.railway.app

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
